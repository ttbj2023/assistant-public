# Personal Agent Assistant v1.9.0 - 环境变量配置示例
#
# 环境变量只保存密钥、provider端点、部署拓扑、测试/调试开关
# 业务配置请写入 config.yaml；详细规则见 docs/configuration.md

# ==========================================
# 运行时/调试配置
# ==========================================
# 运行环境：development/production/testing
ENVIRONMENT = development

# 统一调试开关：控制所有调试功能（Agent追踪、性能监控、错误捕获等）
DEBUG = false

# ==========================================
# 模型API密钥 - 按需配置
# ==========================================
# DeepSeek API密钥（对话模型、内容分析器）
DEEPSEEK_API_KEY = ""

# OpenAI API密钥（Health Assistant对话模型）
OPENAI_API_KEY = ""

# MiniMax API密钥（LLM provider 接入, 默认未使用）
MINIMAX_API_KEY = ""

# 智谱AI API密钥（zhipu_web_reader 网页阅读工具）
ZHIPU_API_KEY = ""

# Gemini API密钥（GeoResearchTool搜索）
GEMINI_API_KEY = ""

# 火山引擎Doubao视觉模型（图片描述/图片生成，可选）
ARK_API_KEY = ""

# 火山引擎Agent Plan（datapro_search / doubao_web_search，可选）
ARK_AGENT_PLAN_API_KEY = ""

# 阿里云Dashscope（部分模型provider，可选）
DASHSCOPE_API_KEY = ""

# 阿里云Token Plan（部分模型provider，可选）
ALIYUN_TOKEN_PLAN_API_KEY = ""

# 超算互联网scnet.cn聚合订阅（Kimi/MiniMax/MiMo/GLM等多模型聚合，可选）
SCNET_API_KEY = ""

# ==========================================
# Provider Base URL 覆盖（可选）
# ==========================================
# 以下变量可由 provider_registry.py 读取，覆盖 config.yaml 中的默认 endpoint
# LOCAL_BASE_URL=http://localhost:11434/v1
# LOCAL_EMBEDDING_BASE_URL=http://localhost:11434/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# GEMINI_BASE_URL=
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_AGENT_PLAN_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
# ALIYUN_TOKEN_PLAN_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# SCNET_BASE_URL=https://api.scnet.cn/api/llm/v1

# ==========================================
# 地图服务（可选，启用 geo_navigator / weather_query 时配置）
# ==========================================
BAIDU_MAPS_AK = ""
TENCENT_MAPS_KEY = ""
TENCENT_MAPS_SK = ""

# ==========================================
# OpenClaw Gateway（主动发消息渠道）
# ==========================================
# URL 是部署拓扑，可在 Docker compose 中覆盖；token 是密钥，只放 .env
OPENCLAW_GATEWAY_URL = ""
OPENCLAW_GATEWAY_TOKEN = ""

# ==========================================
# 其他运行时开关（可选）
# ==========================================
# 服务端口运行时覆盖
# API_PORT=8000
# 用户数据根目录
# BASE_DATA_PATH=./data
# 流式响应中工具调用<details>展示
# ENABLE_TOOL_CALL_DISPLAY=true
# tool-runtime / quote-service 服务地址（Docker 通常由 compose 注入）
# TOOL_RUNTIME_BASE_URL=http://127.0.0.1:8766
# QUOTE_SERVICE_BASE_URL=http://127.0.0.1:8767

# ==========================================
# 邮件SMTP配置 (定时消息邮件渠道)
# ==========================================
# 所有 SMTP 字段都支持留空回退; config.yaml.smtp 对应字段也都可留空走 .env
SMTP_HOST = ""
SMTP_USERNAME = ""
SMTP_PASSWORD = ""
SMTP_FROM_ADDRESS = ""

# ==========================================
# 功能开关配置
# ==========================================
# 静态用户管理开关：启用基于YAML的静态用户管理
ENABLE_STATIC_USER_MANAGEMENT = true

# ==========================================
# 文件下载签名配置（必填1个）
# ==========================================
# 文件下载URL的HMAC签名密钥（必填, 缺失则服务启动失败）
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
FILE_SIGNING_SECRET = ""

# 文件下载URL默认有效期天数（可选, 默认30天, 0=永久）
# FILE_URL_TTL_DAYS=30

# 文件下载对外公网URL（可选, 缺失时使用 host:port/v1/files/dl）
# 直连模式: FILE_SERVER_BASE_URL="http://127.0.0.1:8000/v1/files/dl"
# CF Tunnel 路径分发: FILE_SERVER_BASE_URL="https://ai.jftcloud.cn/pc/v1/files/dl" (开发)
#                     FILE_SERVER_BASE_URL="https://ai.jftcloud.cn/mac/v1/files/dl" (生产)
# FILE_SERVER_BASE_URL="http://127.0.0.1:8000/v1/files/dl"

# ==========================================
# 其他配置说明
# ==========================================
# 以下配置项不要写入环境变量：
# - inference/tool/core/storage 等业务参数
# - 内置工具 class_path/description/group members
# - Agent prompt/tools/memory（写入 agent.yaml）
# - AI模型配置（模型名称、参数等）
# - 记忆系统配置（token预算、向量存储等）
# - 工具系统配置（超时、并发数等）
# - 缓存配置（大小、TTL等）
#
# 模型端点配置示例（在config.yaml中）：
# - local_endpoint: "http://localhost:11434/v1"
# - deepseek_endpoint: "https://api.deepseek.com"
# - openai_endpoint: "https://api.openai.com/v1"
#
# ==========================================
# 使用示例
# ==========================================
#
# 开发环境：
# ENVIRONMENT=development
# DEBUG=true
# DEEPSEEK_API_KEY=your_key_here
# ENABLE_STATIC_USER_MANAGEMENT=true
#
# 生产环境：
# ENVIRONMENT=production
# DEBUG=false
# DEEPSEEK_API_KEY=your_key_here
# ENABLE_STATIC_USER_MANAGEMENT=true
#
# 测试环境：
# ENVIRONMENT=testing
# DEBUG=false
# ENABLE_STATIC_USER_MANAGEMENT=true
